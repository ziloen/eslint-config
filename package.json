{
  "name": "@ziloen/eslint-config",
  "version": "0.1.81",
  "author": "ziloen",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "inspect": "pnpm dlx @eslint/config-inspector@latest",
    "prepack": "tsdown --minify",
    "release": "bumpp --commit --no-push && npm publish",
    "lint": "cross-env TIMING=50 eslint ."
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@eslint-react/eslint-plugin": "3.0.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-ziloen": "^0.1.20",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "bumpp": "^11.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "react": "^19.2.5",
    "tsdown": "0.21.8",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "eslint": "^10"
  }
}